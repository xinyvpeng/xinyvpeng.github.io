<!-- 森林图书馆主题脚本注入 -->
{% if theme.forest_theme.enable %}
  <!-- 森林主题核心脚本 -->
  <script src="{{ url_for('/js/forest/forest-theme.js') }}" defer></script>
  
  {% if theme.forest_theme.scripts %}
    {% for script in theme.forest_theme.scripts %}
      {% if script != '/js/forest/forest-theme.js' %}
        <script src="{{ url_for(script) }}" defer></script>
      {% endif %}
    {% endfor %}
  {% endif %}
  
  <!-- 主题初始化脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof window.ForestTheme !== 'undefined') {
        // 主题管理器会自动初始化
        console.log('🌲 森林主题加载完成');
      } else {
        console.warn('🌲 森林主题脚本未正确加载');
      }
    });
  </script>
  
  <!-- 音频系统配置注入 -->
  {%- if theme.forest_theme.features.audio %}
  <script>
    // 音频系统配置
    window.FOREST_AUDIO_CONFIG = {
      enabled: {{ theme.forest_theme.audio.enabled | default(false) }},
      default_preset: '{{ theme.forest_theme.audio.default_preset | default("morning") }}'
    };
  </script>
  {%- endif %}
  
  <!-- 成就系统配置注入 -->
  {%- if theme.forest_theme.features.achievements %}
  <script>
    // 成就系统配置
    window.FOREST_ACHIEVEMENTS_CONFIG = {
      enabled: {{ theme.forest_theme.achievements.enabled | default(false) }},
      show_notifications: {{ theme.forest_theme.achievements.show_notifications | default(true) }},
      show_progress_indicator: {{ theme.forest_theme.achievements.show_progress_indicator | default(true) }},
      max_plants: {{ theme.forest_theme.achievements.max_plants | default(12) }},
      achievement_sound: {{ theme.forest_theme.achievements.achievement_sound | default(true) }}
    };
  </script>
  {%- endif %}
  
  <!-- 森林主题脚本初始化 -->
  {%- if theme.forest_theme.features %}
  <script>
    // 等待DOM加载完成
    document.addEventListener('DOMContentLoaded', function() {
      // 初始化主题系统
      if (typeof window.ForestTheme !== 'undefined') {
        window.ForestTheme.init();
      }
      
      // 初始化交互系统（延迟确保主题已加载）
      setTimeout(function() {
        if (typeof window.ForestInteractions !== 'undefined' && 
            theme.forest_theme.features.hidden_animals) {
          window.ForestInteractions.init();
        }
        
        // 初始化音频系统
        if (typeof window.ForestAudio !== 'undefined' && 
            theme.forest_theme.features.audio) {
          window.ForestAudio.init();
        }
        
        // 初始化成就系统
        if (typeof window.ForestAchievements !== 'undefined' && 
            theme.forest_theme.features.achievements) {
          window.ForestAchievements.init();
        }
      }, 300);
    });
  </script>
  {%- endif %}
{% endif %}