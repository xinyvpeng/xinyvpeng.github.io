<!-- 森林图书馆主题脚本注入 -->
{% if theme and theme.forest_theme and theme.forest_theme.enable %}
  <!-- 森林主题核心脚本 -->
  <script src="{{ url_for('/js/forest/forest-theme.js') }}" defer></script>
  
  {% if theme.forest_theme.scripts %}
    {% for script in theme.forest_theme.scripts %}
      {% if script != '/js/forest/forest-theme.js' %}
        <script src="{{ url_for(script) }}" defer></script>
      {% endif %}
    {% endfor %}
  {% endif %}
  
  <!-- 主题初始化脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof window.ForestTheme !== 'undefined') {
        // 主题管理器会自动初始化
        console.log('🌲 森林主题加载完成');
      } else {
        console.warn('🌲 森林主题脚本未正确加载');
      }
    });
  </script>
  
  <!-- 音频系统配置注入 -->
  {%- if theme.forest_theme.features and theme.forest_theme.features.audio %}
  <script>
    // 音频系统配置
    window.FOREST_AUDIO_CONFIG = {
      enabled: {{ theme.forest_theme.audio.enabled | default(false) | dump }},
      default_preset: {{ theme.forest_theme.audio.default_preset | default("morning") | dump }}
    };
  </script>
  {%- endif %}
  
  <!-- 成就系统配置注入 -->
  {%- if theme.forest_theme.features and theme.forest_theme.features.achievements %}
  <script>
    // 成就系统配置
    window.FOREST_ACHIEVEMENTS_CONFIG = {
      enabled: {{ theme.forest_theme.achievements.enabled | default(false) | dump }},
      show_notifications: {{ theme.forest_theme.achievements.show_notifications | default(true) | dump }},
      show_progress_indicator: {{ theme.forest_theme.achievements.show_progress_indicator | default(true) | dump }},
      max_plants: {{ theme.forest_theme.achievements.max_plants | default(12) | dump }},
      achievement_sound: {{ theme.forest_theme.achievements.achievement_sound | default(true) | dump }}
    };
  </script>
  {%- endif %}
  
  <!-- 功能配置注入 -->
  {%- if theme.forest_theme.features %}
  <script>
    window.FOREST_THEME_FEATURES = {
      audio: {{ theme.forest_theme.features.audio | default(false) | dump }},
      achievements: {{ theme.forest_theme.features.achievements | default(false) | dump }},
      hidden_animals: {{ theme.forest_theme.features.hidden_animals | default(false) | dump }}
    };
  </script>
  {%- endif %}
{% endif %}