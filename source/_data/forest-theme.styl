// 森林图书馆主题变量定义
// 日间模式变量
:root {
  // 主色调（森林基础）
  --primary-forest-deep: #2d5016;
  --primary-forest-medium: #3e6a23;
  --primary-forest-light: #5a8c3a;
  
  // 强调色（自然元素）
  --accent-amber: #c77d1f;
  --accent-gold: #daa520;
  --accent-sunlight: #f4d35e;
  
  // 背景系统
  --bg-dark: #121a0f;
  --bg-medium: #1c2516;
  --bg-light: #26311d;
  
  // 文字颜色
  --text-primary: #e8f1e1;
  --text-secondary: #b8c9ab;
  --text-accent: #f4d35e;
  
  // 主题状态（供JavaScript检测当前模式）
  --theme-mode: 'day';
  
  // RGB变量（用于rgba）
  --text-accent-rgb: 244, 211, 94;
  --primary-forest-medium-rgb: 62, 106, 35;
}

// 夜间模式变量覆盖
[data-theme="dark"],
[data-theme="night"] {
  --theme-mode: 'night';
  --bg-dark: #0c1208;
  --bg-medium: #141c0e;
  --bg-light: #1c2516;
  --text-primary: #d8e1d0;
  --text-accent: #ffd166;
  --text-accent-rgb: 255, 209, 102;
}

// 应用CSS变量到基础元素
body {
  background-color: var(--bg-dark);
  color: var(--text-primary);
  transition: background-color 0.3s ease, color 0.3s ease;
}

// 链接样式
a {
  color: var(--text-accent);
  text-decoration: none;
  border-bottom: 1px solid unquote('rgba(var(--text-accent-rgb), 0.3)');
  
  &:hover {
    color: var(--accent-amber);
    border-bottom-color: var(--accent-amber);
  }
}

// 按钮样式
.btn {
  background-color: unquote('rgba(var(--primary-forest-medium-rgb), 0.1)');
  color: var(--text-accent);
  border: 1px solid var(--primary-forest-medium);
  
  &:hover {
    background-color: unquote('rgba(var(--primary-forest-medium-rgb), 0.2)');
    color: var(--accent-amber);
  }
}

@import "forest-animations";